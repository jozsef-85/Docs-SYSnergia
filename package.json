{
  "name": "sysnergia-editorial",
  "version": "0.1.0",
  "private": true,
  "description": "Entorno de desarrollo para SYSnergia Docs.",
  "type": "module",
  "scripts": {
    "check": "node scripts/check-content.mjs",
    "check:watch": "node scripts/check-content.mjs --watch",
    "serve": "python3 -m http.server 4173 --directory docs",
    "dev": "node scripts/dev.mjs",
    "guide:prompt": "node scripts/create-guide-prompt.mjs",
    "guide:list": "node scripts/guide-backlog.mjs list",
    "guide:next": "node scripts/guide-backlog.mjs next",
    "guide:next-prompt": "node scripts/guide-backlog.mjs prompt"
  }
}
